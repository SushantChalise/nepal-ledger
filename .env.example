# Nepal Ledger — environment variables template.
# Copy this file to `.env.local` and fill in values. `.env.local` is gitignored.
# DO NOT commit secrets. Production secrets live in Cloudflare Workers + GitHub Actions
# (per ADR-0002 — hosting is Cloudflare Workers via @opennextjs/cloudflare, not Pages).

# ─── Supabase ─────────────────────────────────────────────────────
# https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server-only, never expose to client
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# ─── Supabase Storage (source-document archive — Year 1) ──────────
# Same Supabase project as the database; no separate credentials.
# Bucket: `source-archive` (created at bootstrap via SQL or dashboard)
SUPABASE_STORAGE_BUCKET=source-archive
# Public-read URLs are minted on-demand from SUPABASE_URL + bucket key
# in src/lib/storage/index.ts

# ─── Cloudflare R2 (Phase 2 — once payment method is on file) ─────
# Uncomment when migrating per ADR-0004. Until then, leave commented.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=nepal-ledger-source-archive
# R2_PUBLIC_URL=https://archive.<domain>.com

# ─── Resend (email + newsletter) ──────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@nepalledger.com
RESEND_NEWSLETTER_AUDIENCE_ID=

# ─── Sentry (error tracking) ──────────────────────────────────────
# https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...
SENTRY_AUTH_TOKEN=                            # for source map uploads in CI
SENTRY_ORG=nepal-ledger
SENTRY_PROJECT=javascript-nextjs           # Sentry's platform-default name; do not rename

# ─── Cloudflare Web Analytics ─────────────────────────────────────
# https://dash.cloudflare.com → Analytics → Web Analytics
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
