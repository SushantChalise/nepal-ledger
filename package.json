{
  "name": "nepal-ledger",
  "version": "0.0.0",
  "private": true,
  "description": "Nepal Ledger — tracking whether Nepal's money becomes wealth.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "gen:source-index": "tsx scripts/gen-source-index.ts",
    "check:source-registry": "tsx scripts/check-source-registry.ts",
    "ingest:census-2021": "tsx scripts/ingest-census-2021.ts",
    "probe:nrb-bfi": "python -m scrapers.nrb_bfi.schema_probe",
    "ingest:bfi-monthly": "tsx scripts/ingest-bfi-monthly.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "nepali-date-converter": "^3.4.0",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251111.0",
    "@opennextjs/cloudflare": "^1.10.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks",
      "workerd"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && pnpm typecheck && (command -v gitleaks >/dev/null 2>&1 && gitleaks detect --no-banner --redact --staged || echo 'gitleaks not installed locally — relying on CI gitleaks-action')"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,json,yml,yaml,jsonc}": [
      "prettier --write"
    ]
  }
}
